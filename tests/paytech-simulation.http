# SELECT event_id, order_id, provider, amount, status, processed_at
# FROM payment_events
# WHERE event_id LIKE 'pt_smoke_%'
# ORDER BY processed_at DESC
# LIMIT 10;
#
# -- Vérifie la session PayTech
# SELECT token, order_id, status, created_at, completed_at
# FROM paytech_sessions
# WHERE token LIKE 'pt_smoke_%'
# ORDER BY created_at DESC
# LIMIT 10;
#
# -- Idempotence : le même event_id ne doit pas créer deux lignes
# SELECT event_id, count(*) FROM payment_events GROUP BY event_id HAVING count(*) > 1;
