# ─────────────────────────────────────────────────────────────────────────────
# YONNE — Template de configuration production
# Ce fichier est un MODÈLE uniquement. Ne jamais y mettre de vraies valeurs.
# Pour déployer sur Vercel : Dashboard → Project Settings → Environment Variables
# Pour tester localement en mode prod : copier vers .env.production.local (gitignored)
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_ENV=production

# ── Supabase (Production Project) ─────────────────────────────────────────────
# Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://VOTRE_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Clé service-role : accès complet, contourne RLS.
# Uniquement côté serveur (API Routes / Server Actions). Ne jamais exposer au client.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Authentification JWT ───────────────────────────────────────────────────────
# Secret pour signer les tokens YONNE. Doit être identique à la valeur configurée
# dans Supabase Dashboard → Settings → API → JWT Secret.
# Générer avec : openssl rand -base64 48
AUTH_SECRET=REMPLACER_PAR_UNE_VALEUR_ALEATOIRE_DE_48_BYTES

# ── Africa's Talking (SMS Production) ─────────────────────────────────────────
# https://account.africastalking.com/ → API Key
# AT_USERNAME doit être votre username de PRODUCTION (pas "sandbox")
AT_API_KEY=atsk_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
AT_USERNAME=yonne_production

# ── Paiements Wave / Orange Money (Webhooks) ───────────────────────────────────
# Secret partagé entre YONNE et le fournisseur de paiement pour signer les callbacks.
# Doit être identique à la valeur configurée dans le Dashboard Wave/Orange.
# Générer avec : openssl rand -hex 32
PAYMENT_WEBHOOK_SECRET=REMPLACER_PAR_SECRET_ALEATOIRE_32_BYTES_HEX
